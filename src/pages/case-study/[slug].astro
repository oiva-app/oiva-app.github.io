---
import { render, type CollectionEntry } from "astro:content";
import ContentPageLayout from "../../components/ContentPageLayout.astro";
import {
  getSectionEntries,
  mapSectionPagesWithHeadings,
  type SectionPage,
} from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getSectionEntries("caseStudy");
  const pages = await mapSectionPagesWithHeadings("caseStudy", entries);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, pages },
  }));
}

type Props = {
  entry: CollectionEntry<"caseStudy">;
  pages: SectionPage[];
};

const { entry, pages } = Astro.props;
const { Content } = await render(entry);
---

<ContentPageLayout
  section="caseStudy"
  title={entry.data.title}
  description={entry.data.description}
  currentPageId={entry.id}
  pages={pages}
>
  <Content />
</ContentPageLayout>
