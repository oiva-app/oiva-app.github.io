---
import { render, type CollectionEntry } from "astro:content";
import ContentPageLayout from "../../components/ContentPageLayout.astro";
import {
  getSectionEntries,
  mapSectionPages,
  toHeadingLinks,
} from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getSectionEntries("gettingStarted");

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, entries },
  }));
}

type Props = {
  entry: CollectionEntry<"gettingStarted">;
  entries: CollectionEntry<"gettingStarted">[];
};

const { entry, entries } = Astro.props;
const { Content, headings } = await render(entry);
const pages = mapSectionPages("gettingStarted", entries);
const headingLinks = toHeadingLinks(headings);
---

<ContentPageLayout
  section="gettingStarted"
  title={entry.data.title}
  description={entry.data.description}
  currentPageId={entry.id}
  pages={pages}
  headings={headingLinks}
>
  <Content />
</ContentPageLayout>
