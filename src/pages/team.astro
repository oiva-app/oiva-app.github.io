---
import TeamProfile from "../components/TeamProfile.astro";
import { teamMembers } from "../data/team";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Our Team" description="Meet the team building Oiva.">
  <section class="team-page">
    <p class="eyebrow">Team</p>
    <h1>Our Team</h1>
    <p class="intro">Placeholder profile layout for the Oiva team. Headshots and email links are intentionally deferred.</p>

    <div class="team-grid">
      {teamMembers.map((member) => <TeamProfile member={member} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .team-page {
    margin: 0 auto;
    max-width: var(--container-wide);
    padding: var(--space-section) var(--space-page) 0;
    text-align: center;
  }

  h1 {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    line-height: 1;
    margin: 0;
  }

  .intro {
    color: var(--color-muted);
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 1rem auto 2.5rem;
    max-width: 42rem;
  }

  .team-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  @media (max-width: 980px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
