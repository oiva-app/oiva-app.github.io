---
import type { HeadingLink, SectionPage } from "../lib/content";

type Props = {
  title: string;
  pages: SectionPage[];
  currentPageId: string;
  headings: HeadingLink[];
};

const { title, pages, currentPageId, headings } = Astro.props;
---

<aside class="section-sidebar">
  <nav aria-label={`${title} pages`}>
    <p class="sidebar-title">{title}</p>
    {pages.map((page) => (
      <a class="page-link" href={page.href} aria-current={page.id === currentPageId ? "page" : undefined}>
        {page.label}
      </a>
    ))}
  </nav>

  {headings.length > 0 && (
    <nav class="heading-links" aria-label="On this page">
      <p class="sidebar-title">On this page</p>
      {headings.map((heading) => (
        <a href={`#${heading.slug}`}>{heading.text}</a>
      ))}
    </nav>
  )}
</aside>

<style>
  .section-sidebar {
    align-self: start;
    display: grid;
    gap: 1.75rem;
    max-height: calc(100vh - 6rem);
    overflow: auto;
    position: sticky;
    top: 5.5rem;
  }

  nav {
    display: grid;
    gap: 0.25rem;
  }

  .sidebar-title {
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 800;
    margin: 0 0 0.35rem;
    text-transform: uppercase;
  }

  a {
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-size: 0.94rem;
    font-weight: 600;
    line-height: 1.35;
    padding: 0.45rem 0.6rem;
    text-decoration: none;
  }

  a:hover,
  a[aria-current="page"] {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .heading-links {
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
  }

  .heading-links a {
    font-size: 0.88rem;
  }

  @media (max-width: 900px) {
    .section-sidebar {
      display: none;
    }
  }
</style>
