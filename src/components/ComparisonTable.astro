---
import Check from "../assets/icon/check.svg";
import X from "../assets/icon/x.svg";

type Mark = "yes" | "partial" | "no";
type Cell = Mark | { mark: Mark; note: string };

// Lucide icons with ASCII fallback
const MARKS: Record<Mark, { glyph: string; label: string; className: string; Icon?: typeof Check }> = {
  yes: { glyph: "Y", label: "yes", className: "mark-yes", Icon: Check },
  partial: { glyph: "~", label: "partial or limited", className: "mark-partial" },
  no: { glyph: "N", label: "no / not a focus", className: "mark-no", Icon: X },
};

const columnHeadings: { name: string; examples?: string; isOiva?: boolean }[] = [
  { name: "Oiva", isOiva: true },
  { name: "Standalone autonomous agents", examples: "Cleric, Resolve AI, Traversal" },
  { name: "IncidentFox"},
  { name: "Observability-platform-native", examples: "Datadog Bits AI, Dynatrace Davis" },
  { name: "Incident-management platforms", examples: "incident.io, Rootly" },
];

const rows: { criterion: string; cells: Cell[] }[] = [
  { criterion: "Open-source", cells: ["yes", "no", "yes", "no", "no"] },
  { criterion: "Self-hostable", cells: ["yes", "no", "yes", "no", "no"] },
  { criterion: "Obs-stack neutral", cells: ["yes", "yes", "yes", "no", "partial"] },
  { criterion: "Wide-event focused", cells: ["yes", "no", "no", "no", "no"] },
  { criterion: "Transparent, reproducible evals", cells: ["yes", "partial", "partial", "partial", "no"] },
  { criterion: "Read-Write Agent", cells: [{ mark: "no", note: "read-only" }, "yes", "partial", "partial", "yes"] },
  { criterion: "Continuous Learning", cells: ["no", "yes", "yes", "yes", "yes"] },
];

const cellOf = (c: Cell): { mark: Mark; note?: string } =>
  typeof c === "string" ? { mark: c } : c;
---

<figure class="comparison">
  <div class="comparison-scroll" tabindex="0" aria-label="Comparison table">
    <table>
      <caption class="sr-only">
        Existing solutions — comparison of Oiva against other AI SRE tool categories.
      </caption>
      <thead>
        <tr>
          <th scope="col" class="corner"><span class="sr-only">Capability</span></th>
          {
            columnHeadings.map((solution) => (
              <th scope="col" class:list={["solution", solution.isOiva && "is-oiva"]}>
                <span class="solution-name">{solution.name}</span>
                {solution.examples && <span class="solution-examples">{solution.examples}</span>}
              </th>
            ))
          }
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <th scope="row" class="criterion">
                {row.criterion}
              </th>
              {row.cells.map((cell, i) => {
                const { mark, note } = cellOf(cell);
                const meta = MARKS[mark];
                const Icon = meta.Icon;
                return (
                  <td class:list={[columnHeadings[i]?.isOiva && "is-oiva"]}>
                    <span class:list={["mark", meta.className]}>
                      <span class="glyph" aria-hidden="true">
                        {Icon ? <Icon /> : meta.glyph}
                      </span>
                      <span class="sr-only">{meta.label}</span>
                    </span>
                    {note && <span class="cell-note">({note})</span>}
                  </td>
                );
              })}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <figcaption class="legend">
    <span class="legend-title">Legend:</span>
    {
      Object.values(MARKS).map((meta) => {
        const Icon = meta.Icon;
        return (
          <span class="legend-item">
            <span class:list={["mark", meta.className]}>
              <span class="glyph" aria-hidden="true">
                {Icon ? <Icon /> : meta.glyph}
              </span>
            </span>
            {meta.label}
          </span>
        );
      })
    }
  </figcaption>
</figure>

<style>
  .comparison {
    margin: var(--space-md) 0;
  }

  .comparison-scroll {
    border: 1px solid var(--border-subtle);
    overflow-x: auto;
  }

  .comparison table {
    border-collapse: collapse;
    display: table;
    margin: 0;
    width: 100%;
  }

  .comparison th,
  .comparison td {
    border-bottom: 1px solid var(--border-subtle);
    border-right: 1px solid var(--border-subtle);
    padding: calc(var(--space-sm) / 2) calc(var(--space-md) / 2);
    text-align: center;
    vertical-align: middle;
  }

  .comparison tr > :last-child {
    border-right: 0;
  }

  .comparison tbody tr:last-child th,
  .comparison tbody tr:last-child td {
    border-bottom: 0;
  }

  /* Column headings — solution names */
  .comparison thead th {
    background: var(--color-surface-muted);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 700;
    line-height: var(--leading-ui);
  }

  .comparison .solution {
    min-width: 8rem;
  }

  .comparison .solution-name {
    display: block;
  }

  .comparison .solution-examples {
    color: var(--color-text-subtle);
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    margin-top: var(--space-2xs);
  }

  /* Row headings */
  .comparison .criterion,
  .comparison .corner {
    left: 0;
    position: sticky;
    text-align: left;
    background: var(--color-surface-muted);
    z-index: 1;
  }

  .comparison .criterion {
    background: var(--color-surface-muted);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 650;
    min-width: 7rem;
  }

  .comparison .corner {
    background: var(--color-surface-muted);
    z-index: 2;
  }

  .comparison thead .is-oiva {
    color: var(--color-primary);
  }

  /* Marks */
  .comparison .mark {
    align-items: center;
    display: inline-flex;
    justify-content: center;
    vertical-align: middle;
  }

  .comparison .glyph {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
  }

  .comparison .glyph :global(svg) {
    display: block;
    height: 1.5rem;
    width: 1.5rem;
  }

  .comparison .mark-yes .glyph {
    color: var(--color-accent-green);
  }

  .comparison .mark-partial .glyph {
    color: var(--color-accent-yellow);
  }

  .comparison .mark-no .glyph {
    color: var(--color-accent-coral);
  }

  .comparison .cell-note {
    color: var(--color-text-subtle);
    display: block;
    font-size: var(--text-xs);
    margin-top: var(--space-2xs);
  }

  /* Legend */
  .legend {
    align-items: center;
    color: var(--color-text-muted);
    display: flex;
    flex-wrap: wrap;
    font-size: var(--text-sm);
    gap: var(--space-xs) var(--space-md);
    margin-top: var(--space-sm);
  }

  .legend-title {
    color: var(--color-text);
    font-weight: 700;
  }

  .legend-item {
    align-items: center;
    display: inline-flex;
    gap: var(--space-2xs);
  }
</style>
